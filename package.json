{
  "name": "project-x",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "--- DB SECTION ---": "--- --- --- --- ---",
    "db:migrate:dev": "npx env-cmd -f .env npx prisma migrate dev",
    "db:push:dev": "npx env-cmd -f .env npx prisma db push",
    "db:generate": "npx env-cmd -f .env npx prisma generate",
    "db:studio": "npx env-cmd -f .env npx prisma studio",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/system": "^7.3.9",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "dotenv": "^17.3.1",
    "isbot": "^5.1.31",
    "mongodb": "^7.1.0",
    "motion": "^12.36.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router": "7.12.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/material-ui": "^0.21.18",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-tap-event-plugin": "^0.0.33",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
