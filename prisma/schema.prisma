generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id              Int               @id @default(autoincrement())
  type            String
  identity        String
  abbr            String
  name            String
  chineseName     String?
  address1        String?
  address2        String?
  phoneNumber     String?
  email           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  date            DateTime?
  gender          String
  industry        String?
  natureOfWork    String?
  workDescription String?
  remark          String?
  files           ClientFile[]
  policies        InsurancePolicy[]
}

model InsurancePolicy {
  id                 Int                  @id @default(autoincrement())
  uuid               String               @unique @default(uuid())
  processType        String
  category           String
  policyNumber       String               @unique
  quotationNumber    String?
  remark             String?
  clientId           Int
  insuranceCompanyId Int
  brokerId           Int
  effectiveDate      DateTime
  expiryDate         DateTime
  premiumAmount      Float?
  currency           String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  previousPolicyId   Int?                 @unique
  homeDetail         HomePolicyDetail?
  broker             Broker               @relation(fields: [brokerId], references: [id])
  client             Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  insuranceCompany   InsuranceCompany     @relation(fields: [insuranceCompanyId], references: [id])
  previousPolicy     InsurancePolicy?     @relation("PolicyHistory", fields: [previousPolicyId], references: [id])
  nextPolicy         InsurancePolicy?     @relation("PolicyHistory")
  lifeDetail         LifePolicyDetail?
  vehicleDetail      VehiclePolicyDetail?
}

model VehiclePolicyDetail {
  id                 Int             @id @default(autoincrement())
  policyId           Int             @unique
  coverageType       String
  registrationNumber String
  vehicleType        String
  engineNumber       String?
  chassisNumber      String?
  vehicleBodyType    String
  manufacturer       String?
  modelName          String?
  enginDisplacement  Float
  totalWeight        Float
  yearOfManufacture  Int
  seatNumber         Float
  region             String
  moneyLenderLicence String?
  policy             InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model HomePolicyDetail {
  id                  Int             @id @default(autoincrement())
  policyId            Int             @unique
  propertyAddress     String
  propertyType        String
  sumInsuredStructure Float?
  isMortgaged         Boolean         @default(false)
  policy              InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model LifePolicyDetail {
  id              Int             @id @default(autoincrement())
  policyId        Int             @unique
  beneficiaryName String
  sumAssured      Float
  medicalRequired Boolean         @default(false)
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

model InsuranceCompany {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  policies InsurancePolicy[]
}

model Broker {
  id       Int               @id @default(autoincrement())
  name     String            @unique
  policies InsurancePolicy[]
}

model ClientFile {
  id          Int      @id @default(autoincrement())
  name        String
  path        String
  description String
  size        Int
  mimeType    String
  uploadedAt  DateTime @default(now())
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Currency {
  id   Int    @id @default(autoincrement())
  abbr String @unique
  rate Float
}
