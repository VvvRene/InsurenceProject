// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Client {
  id              Int               @id @default(autoincrement())
  type            String            // "Company" | "Individual"
  identity        String            // BR Number | HKID 
  
  abbr            String            // MR, MS, MISS
  name            String 
  chineseName     String?

  address1        String
  address2        String?

  phoneNumber     String 
  email           String?
 
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // 
  date            DateTime?
  gender          String             // Male. Female, not applicatable
  
  industry        String?
  natureOfWork    String?
  workDescription String? 
  remark          String?
  
  // Relations
  policies        InsurancePolicy[]
  files           ClientFile[]
}

model InsurancePolicy {
  id                      Int               @id @default(autoincrement())
  uuid                    String            @unique @default(uuid())
  
  // 1. Process Type: "New" | "Renewal"
  processType             String            // "New" | "Renewal"
  
  // 2. Product Category: "
  category                String            // Vehicle" | "Home" | "Life"
  
  status                  String            // "Active" | "Lapsed" | "Pending"
  policyNumber            String            @unique 
  quotationNumber         String?

  // Ownership Relations
  clientId                Int
  client                  Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)  
  
  insuranceCompanyId      Int
  insuranceCompany        InsuranceCompany  @relation(fields: [insuranceCompanyId], references: [id])

  brokerId                Int
  broker                  Broker            @relation(fields: [brokerId], references: [id])

  // Common Policy Data
  effectiveDate           DateTime 
  expiryDate              DateTime 
  premiumAmount           Float?            
  currency                String?           
  
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  // --- Category-Specific Details ---
  // Only ONE of these should be populated based on the 'category' field
  vehicleDetail           VehiclePolicyDetail?
  homeDetail              HomePolicyDetail?
  lifeDetail              LifePolicyDetail?
}

// 🚗 Vehicle Category
model VehiclePolicyDetail {
  id                  Int             @id @default(autoincrement())
  
  policyId            Int             @unique // Ensures 1:1
  policy              InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  coverageType        String          // "Comprehensive" ｜ "Third Party"
  registrationNumber  String  

  vehicleType         String
  engineNumber        String? 
  chassisNumber       String?  
  vehicleBodyType     String
  manufacturer        String? 
  modelName           String?  
  enginDisplacement   Float
  totalWeight         Float
  yearOfManufacture   Int
  seatNumber          String

  region              String        // HK | HK+SZ
  moneyLenderLicence  String?

}

// 🏠 Homeowner’s Category
model HomePolicyDetail {
  id                  Int             @id @default(autoincrement())
  policyId            Int             @unique // Ensures 1:1
  policy              InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  propertyAddress     String
  propertyType        String          // "Apartment" | "House"
  sumInsuredStructure Float?          
  isMortgaged         Boolean         @default(false)
}

// 🧬 Life Category
model LifePolicyDetail {
  id                  Int             @id @default(autoincrement())
  policyId            Int             @unique // Ensures 1:1
  policy              InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  beneficiaryName     String
  sumAssured          Float
  medicalRequired     Boolean         @default(false)
}

model InsuranceCompany {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  policies  InsurancePolicy[]
}

model Broker {
  id        Int               @id @default(autoincrement()) 
  name      String            @unique
  policies  InsurancePolicy[]
}

model ClientFile {
  id          Int      @id @default(autoincrement())
  name        String   
  path        String   
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Currency {
  id    Int    @id @default(autoincrement())
  abbr  String @unique 
  rate  Float  
}